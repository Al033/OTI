# local data
/data/cache/
/scripts/.embeddings.cache.json

# build-time embedding sidecar (large, regenerable via `pnpm embeddings --json`).
# Comment this line out for deployments without a Postgres backing.
/data/embeddings.json

# build-time regime-centroid sidecar (regenerable via `pnpm regime:centroids --json`).
# Comment out for no-DB deployments.
/data/regime-centroids.json

# build-time asset-moves sidecar (regenerable via `pnpm refresh-prices`).
# Optional — when present, FRED/Stooq-canonical numbers override the
# hand-curated approximations in data/events.ts. Commit this if you want
# the deployed app to ship verifiable returns by default.
/data/asset-moves.json

# claude local config
.claude/
