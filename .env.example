# --- AI providers (multi-provider via Vercel AI Gateway) ---
# Get this from: https://vercel.com/dashboard/ai-gateway
# Routes to Anthropic / OpenAI / Google / Mistral and embedding models
# (voyage-3-large) with one key.
AI_GATEWAY_API_KEY=

# --- Direct provider keys (optional fallbacks if not using AI Gateway) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Voyage AI rerank pass (recommended for prod) ---
# Enables the rerank-2.5 cross-encoder pass over the top-15 candidates
# before synthesis. Get a key at https://dash.voyageai.com.
# If absent, retrieval still works — the rerank step is just skipped.
VOYAGE_API_KEY=

# --- Default models (provider/model strings via AI Gateway) ---
# Synthesis is the heavy reasoning pass; tagging is cheap classification.
OTI_SYNTH_MODEL=anthropic/claude-sonnet-4-6
OTI_TAG_MODEL=anthropic/claude-haiku-4-5

# --- Embeddings (used by `pnpm embeddings` and at request time) ---
# DEFAULT: voyage-finance-2 (domain-specialised for financial prose).
# OTI's corpus is finance/macro narrative — this is the bullseye use case.
# Voyage's published benchmarks show ~7% NDCG@10 lift over text-embedding-
# 3-large on FinanceBench, and a measurable lift over voyage-4-large on
# filing-density text.
#
# Switch to voyage-4-large for general-purpose corpora or multilingual
# coverage. Both produce 1024d at OTI_EMBEDDING_DIMENSIONS default; they
# live in DIFFERENT vector spaces, so switching requires re-embedding the
# corpus via `pnpm embeddings --force`.
#
# If absent, retrieval falls back to Jaccard-only over the controlled-
# vocabulary regime tags.
OTI_EMBEDDING_MODEL=voyage/voyage-finance-2
OTI_EMBEDDING_DIMENSIONS=1024

# --- Database (Neon Postgres via Vercel Marketplace) ---
# Auto-injected when you install Neon from the Marketplace.
# https://vercel.com/marketplace/neon
# Without this, retrieval reads from data/embeddings.json sidecar
# (generate with `pnpm embeddings --json`) and brief permalinks are
# stored in process memory only.
POSTGRES_URL=

# --- Macro data (Today's Regime feature, v0.3) ---
# St. Louis Fed FRED API. Free, get one at https://fred.stlouisfed.org/docs/api/api_key.html.
# Used by the daily cron at /api/cron/regime-snapshot to pull the live macro
# state vector, and by `pnpm regime:centroids` at build time to populate
# the corpus's historical regime vectors.
FRED_API_KEY=

# --- Distribution (Today's Regime daily digest, v0.3) ---
# Bluesky bot account (free, AT Protocol). The cron at 10:00 UTC posts
# the daily brief headline + OG card to this account.
BSKY_HANDLE=
BSKY_APP_PWD=

# Resend (https://resend.com) for the daily email digest.
RESEND_API_KEY=
RESEND_FROM=daily@oti.example.app
RESEND_AUDIENCE_ID=

# --- Cron security ---
# Required header on /api/cron/* routes; Vercel Cron sets `Authorization:
# Bearer ${CRON_SECRET}` automatically when this is set as an env var.
CRON_SECRET=

# --- Observability (Langfuse Cloud — v0.4) ---
# Hobby tier (free): 50k spans/month, 30-day retention. Auto-instruments
# every AI SDK v6 call (generateObject / streamObject / embed) when set.
# Sign up: https://cloud.langfuse.com.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Vercel Edge Config (v0.5 hot-path reads) ---
# Sub-5ms global reads for the home page TodayStrip + corpus-version
# staleness check. Created via Vercel dashboard → Storage → Edge Config.
# When unset, the home page falls back to Postgres (~80ms).
EDGE_CONFIG=

# Daily cron writes via the Vercel API; these are required for writes.
VERCEL_API_TOKEN=
EDGE_CONFIG_ID=
VERCEL_TEAM_ID=

# --- App config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=false
